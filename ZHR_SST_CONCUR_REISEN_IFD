*&---------------------------------------------------------------------*
*&      Form  FETCH_DATA
*&---------------------------------------------------------------------*
*       Fetch the data from database table
*----------------------------------------------------------------------*
FORM fetch_data .
  DATA: lt_a1_hdr TYPE TABLE OF /nyx/a1_hdr.
  DATA: ls_a1_hdr TYPE /nyx/a1_hdr.
  DATA: ls_pa0002 TYPE pa0002.
  DATA: ls_tr_header TYPE /nyx/sccoreq02v4.
  DATA: ls_dest_list TYPE /nyx/sccoreq21v4.
  DATA: ls_a1_hist TYPE /nyx/a1_hist.

* Get the 'SAVED_0700' trips from /nyx/a1_hdr
  SELECT * FROM /nyx/a1_hdr                   "#EC CI_ALL_FIELDS_NEEDED
  INTO TABLE lt_a1_hdr.            "#EC "#EC CI_NOFIELD "#EC CI_NOWHERE

  IF sy-subrc <> 0.
    MESSAGE ID 'ZHR_SST_CONCUR_MC' TYPE 'E' NUMBER 001.
  ENDIF.

* Filtern the trips based on start date and end date
  IF p_begda IS NOT INITIAL.
    DELETE lt_a1_hdr WHERE begda < p_begda.
  ENDIF.

  IF p_endda IS NOT INITIAL.
    DELETE lt_a1_hdr WHERE endda > p_endda.
  ENDIF.

* Delete entries not in s_pernr
  IF s_pernr IS NOT INITIAL.
    DELETE lt_a1_hdr WHERE pernr NOT IN s_pernr.
  ENDIF.

* Delete entries not in s_land
  IF s_land IS NOT INITIAL.
    DELETE lt_a1_hdr WHERE land NOT IN s_land.
  ENDIF.

* Filtern the trips based on selections
  LOOP AT lt_a1_hdr INTO ls_a1_hdr.
* Take all entries in /nyx/a1_hist with status SAVED_0700
    SELECT SINGLE * FROM /nyx/a1_hist INTO ls_a1_hist WHERE pernr = ls_a1_hdr-pernr AND a1mnr = ls_a1_hdr-a1mnr AND status = 'SAVED_0700'.
    IF sy-subrc <> 0.
      CONTINUE.
    ENDIF.

* Nationality
    IF s_natio IS NOT INITIAL.
      SELECT SINGLE * FROM pa0002 INTO ls_pa0002 WHERE pernr = ls_a1_hdr-pernr AND begda < sy-datum AND endda > sy-datum. "#EC CI_ALL_FIELDS_NEEDED
      IF sy-subrc = 0.
        IF ls_pa0002 NOT IN s_natio.
          CONTINUE.
        ENDIF.
      ENDIF.
    ENDIF.

* Request ID
    IF s_req_nr IS NOT INITIAL.
      SELECT SINGLE * FROM /nyx/sccoreq21v4 INTO ls_dest_list WHERE proc_value = ls_a1_hdr-a1mnr.
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.

      SELECT SINGLE * FROM /nyx/sccoreq02v4 INTO ls_tr_header WHERE doc_id = ls_dest_list-doc_id. "#EC CI_ALL_FIELDS_NEEDED
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.

      IF ls_tr_header-requestid NOT IN s_req_nr.
        CONTINUE.
      ENDIF.
    ENDIF.

* Status
    IF s_twstat IS NOT INITIAL.
      SELECT SINGLE * FROM /nyx/sccoreq21v4 INTO ls_dest_list WHERE proc_value = ls_a1_hdr-a1mnr.
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.

      SELECT SINGLE * FROM /nyx/sccoreq02v4 INTO ls_tr_header WHERE doc_id = ls_dest_list-doc_id. "#EC CI_ALL_FIELDS_NEEDED
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.

      IF ls_tr_header-code_apr NOT IN s_twstat.
        CONTINUE.
      ENDIF.
    ENDIF.

* Append the entry if it fulfilled all the conditions
    APPEND ls_a1_hdr TO gt_a1_hdr.
  ENDLOOP.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  PROCESS_DATA
*&---------------------------------------------------------------------*
*       Filtern the data based on selections and parameters and process data
*----------------------------------------------------------------------*
FORM process_data .
  DATA: ls_a1_hdr TYPE /nyx/a1_hdr.
  DATA: ls_tr_header TYPE /nyx/sccoreq02v4.
  DATA: ls_aus_d     TYPE zhr_sst_concur_reisen_output_s.
  DATA: lt_aus_d     TYPE TABLE OF zhr_sst_concur_reisen_output_s.
  DATA: ls_a1_hist TYPE /nyx/a1_hist.
  DATA: ls_a1_hist_delete TYPE /nyx/a1_hist.
  DATA: ls_a1_dest TYPE /nyx/a1_dest.
  DATA: lt_a1_dest TYPE TABLE OF /nyx/a1_dest.
  DATA: ls_persparm TYPE fpb_persparm.
  DATA: lv_pernr TYPE pernr_d.
  DATA: lv_uname TYPE uname.
  DATA: ls_dest_list TYPE /nyx/sccoreq21v4.
  DATA: ls_log TYPE zhrsst_a1_2.
  DATA: ls_pa0001 TYPE pa0001.
  DATA: lv_trip_id TYPE /nyx/sc_co_req_legid_v04.

  CLEAR: gt_aus_d.
  LOOP AT gt_a1_hdr INTO ls_a1_hdr.
    CLEAR ls_aus_d.

    ls_aus_d-pernr = ls_a1_hdr-pernr.

    SELECT SINGLE * FROM /nyx/sccoreq21v4 INTO ls_dest_list WHERE proc_value = ls_a1_hdr-a1mnr.
    IF sy-subrc <> 0.
      CONTINUE.
    ENDIF.

    SELECT SINGLE * FROM /nyx/sccoreq02v4 INTO ls_tr_header WHERE doc_id = ls_dest_list-doc_id. "#EC CI_ALL_FIELDS_NEEDED
    IF sy-subrc <> 0.
      CONTINUE.
    ENDIF.

    CONCATENATE ls_tr_header-requestid ls_dest_list-segmentlegid INTO ls_aus_d-trip_id.

    SELECT SINGLE * FROM pa0001 INTO ls_pa0001 WHERE pernr = ls_a1_hdr-pernr AND begda <= sy-datum AND endda >= sy-datum.
    IF sy-subrc <> 0.
      CONTINUE.
    ENDIF.

    ls_aus_d-fdf_kostl_pernr = ls_pa0001-kostl.

* Find the approver for traveller
    SELECT SINGLE * FROM fpb_persparm INTO ls_persparm "#EC CI_ALL_FIELDS_NEEDED
      WHERE
        low = ls_aus_d-pernr AND                          "#EC CI_SUBRC
        applid = 'CO-CCA-TR' AND
    fieldname = 'PERNR'.                           "#EC "#EC CI_NOFIRST

    IF sy-subrc = 0.
*   Get Pernr from User
      lv_uname = ls_persparm-perskey.
      CALL FUNCTION 'BAPI_USR01DOHR_GETEMPLOYEE'
        EXPORTING
          id             = lv_uname
        IMPORTING
*         return         = ls_return
          employeenumber = lv_pernr.

      IF sy-subrc = 0.
        ls_aus_d-pernr_rba = lv_pernr.
      ENDIF.
    ENDIF.

* Read data from hist table
    SELECT SINGLE * FROM /nyx/a1_hist INTO ls_a1_hist WHERE pernr = ls_a1_hdr-pernr AND a1mnr = ls_a1_hdr-a1mnr AND status = 'SAVED_0700'. "#EC CI_ALL_FIELDS_NEEDED
    IF sy-subrc = 0.
      ls_aus_d-zland = ls_a1_hdr-land.
      ls_aus_d-datv1 = ls_a1_hist-begda.
      ls_aus_d-datb1 = ls_a1_hist-endda.
      ls_aus_d-dates = ls_a1_hist-date_from.
      ls_aus_d-times = ls_a1_hist-time_from.
    ENDIF.

* Read destinations
    SELECT * FROM /nyx/a1_dest INTO TABLE lt_a1_dest WHERE pernr = ls_a1_hdr-pernr AND a1mnr = ls_a1_hdr-a1mnr.
    IF sy-subrc = 0.
      SORT lt_a1_dest BY bsnr ASCENDING.
      lv_trip_id = ls_aus_d-trip_id.
      LOOP AT lt_a1_dest INTO ls_a1_dest.
        CASE sy-tabix.
          WHEN 1.
            CONCATENATE lv_trip_id '1ST' INTO ls_aus_d-trip_id.
          WHEN 2.
            CONCATENATE lv_trip_id '2ND' INTO ls_aus_d-trip_id.
          WHEN 3.
            CONCATENATE lv_trip_id '3RD' INTO ls_aus_d-trip_id.
          WHEN 4.
            CONCATENATE lv_trip_id '4TH' INTO ls_aus_d-trip_id.
          WHEN 5.
            CONCATENATE lv_trip_id '5TH' INTO ls_aus_d-trip_id.
          WHEN 6.
            CONCATENATE lv_trip_id '6TH' INTO ls_aus_d-trip_id.
          WHEN 7.
            CONCATENATE lv_trip_id '7TH' INTO ls_aus_d-trip_id.
          WHEN 8.
            CONCATENATE lv_trip_id '8TH' INTO ls_aus_d-trip_id.
          WHEN 9.
            CONCATENATE lv_trip_id '9TH' INTO ls_aus_d-trip_id.
          WHEN 10.
            CONCATENATE lv_trip_id '10TH' INTO ls_aus_d-trip_id.
          WHEN 11.
            CONCATENATE lv_trip_id '11TH' INTO ls_aus_d-trip_id.
          WHEN OTHERS.
        ENDCASE.
        ls_aus_d-ankey = ls_a1_dest-t536c_key_bs.
        ls_aus_d-name = ls_a1_dest-name_bs.
        ls_aus_d-stras = ls_a1_dest-strasse_bs.
        ls_aus_d-hausn = ls_a1_dest-hausnr_bs.
        ls_aus_d-plz = ls_a1_dest-plz_bs.
        ls_aus_d-ort = ls_a1_dest-ort_bs.


* If the entry exists with the status DELETE => remove
        SELECT SINGLE * FROM zhrsst_a1_2 INTO ls_log WHERE trip_id = ls_aus_d-trip_id AND a1mnr = ls_a1_hdr-a1mnr AND vp_action = 'DELETE'.
        IF sy-subrc = 0.
          CONTINUE.
        ENDIF.

* If there was a entry in /nyx/a1_hist with the status DELETED
        SELECT SINGLE * FROM /nyx/a1_hist INTO ls_a1_hist_delete WHERE pernr = ls_aus_d-pernr AND a1mnr = ls_a1_hdr-a1mnr AND status = 'DELETED'.
        IF sy-subrc = 0.
          ls_aus_d-tw_status = 'CANCEL'.

          MOVE-CORRESPONDING EXACT ls_aus_d TO ls_log.
          ls_log-a1mnr = ls_a1_hdr-a1mnr.
          ls_log-vp_date = ls_a1_hist_delete-date_from.
          ls_log-vp_time = ls_a1_hist_delete-time_from.
          ls_log-vp_action = 'DELETE'.

          APPEND ls_log TO gt_log.
          APPEND ls_aus_d TO gt_aus_d.
          CONTINUE.
        ENDIF.

* If no entry exists at all => create
        SELECT SINGLE * FROM zhrsst_a1_2 INTO ls_log WHERE trip_id = ls_aus_d-trip_id AND a1mnr = ls_a1_hdr-a1mnr AND tw_status = 'CREATE'.
        IF sy-subrc <> 0.

          ls_aus_d-tw_status = 'APPROVED'.

          MOVE-CORRESPONDING EXACT ls_aus_d TO ls_log.
          ls_log-a1mnr = ls_a1_hdr-a1mnr.
          ls_log-vp_date = ls_a1_hist-date_from.
          ls_log-vp_time = ls_a1_hist-time_from.
          ls_log-vp_action = 'CREATE'.

          APPEND ls_log TO gt_log.
          APPEND ls_aus_d TO gt_aus_d.
          CONTINUE.
        ELSE.
* Compare with entries
          IF ls_log-zland NE ls_aus_d-zland OR ls_log-datv1 NE ls_aus_d-datv1 OR ls_log-datb1 NE ls_aus_d-datb1
            OR ls_log-ankey NE ls_aus_d-ankey OR ls_log-name NE ls_aus_d-name OR ls_log-stras NE ls_aus_d-stras
            OR ls_log-hausn NE ls_aus_d-hausn OR ls_log-plz NE ls_aus_d-plz OR ls_log-ort NE ls_aus_d-ort.

            ls_aus_d-tw_status = 'APPROVED'.

            MOVE-CORRESPONDING EXACT ls_aus_d TO ls_log.
            ls_log-a1mnr = ls_a1_hdr-a1mnr.
            ls_log-vp_date = ls_a1_hist-date_from.
            ls_log-vp_time = ls_a1_hist-time_from.
            ls_log-vp_action = 'CHANGE'.

            APPEND ls_log TO gt_log.
            APPEND ls_aus_d TO gt_aus_d.
            CONTINUE.
          ENDIF.
        ENDIF.
      ENDLOOP.

    ELSE.
* No destinations available
      CONCATENATE ls_aus_d-trip_id '1ST' INTO ls_aus_d-trip_id.

* If the entry exists with the status DELETE => remove
      SELECT SINGLE * FROM zhrsst_a1_2 INTO ls_log WHERE trip_id = ls_aus_d-trip_id AND a1mnr = ls_a1_hdr-a1mnr AND vp_action = 'DELETE'.
      IF sy-subrc = 0.
        CONTINUE.
      ENDIF.


* If there was a entry in /nyx/a1_hist with the status DELETED
      SELECT SINGLE * FROM /nyx/a1_hist INTO ls_a1_hist_delete WHERE pernr = ls_aus_d-pernr AND a1mnr = ls_a1_hdr-a1mnr AND status = 'DELETED'.
      IF sy-subrc = 0.
        ls_aus_d-tw_status = 'CANCEL'.

        MOVE-CORRESPONDING EXACT ls_aus_d TO ls_log.
        ls_log-a1mnr = ls_a1_hdr-a1mnr.
        ls_log-vp_date = ls_a1_hist_delete-date_from.
        ls_log-vp_time = ls_a1_hist_delete-time_from.
        ls_log-vp_action = 'DELETE'.

        APPEND ls_log TO gt_log.
        APPEND ls_aus_d TO gt_aus_d.
        CONTINUE.
      ENDIF.

* If no entry exists at all => create
      SELECT SINGLE * FROM zhrsst_a1_2 INTO ls_log WHERE trip_id = ls_aus_d-trip_id AND a1mnr = ls_a1_hdr-a1mnr AND tw_status = 'CREATE'.
      IF sy-subrc <> 0.
        ls_aus_d-tw_status = 'APPROVED'.

        MOVE-CORRESPONDING EXACT ls_aus_d TO ls_log.
        ls_log-a1mnr = ls_a1_hdr-a1mnr.
        ls_log-vp_date = ls_a1_hist-date_from.
        ls_log-vp_time = ls_a1_hist-time_from.
        ls_log-vp_action = 'CREATE'.

        APPEND ls_log TO gt_log.
        APPEND ls_aus_d TO gt_aus_d.
        CONTINUE.
      ELSE.
* Compare with entries
        IF ls_log-zland NE ls_aus_d-zland OR ls_log-datv1 NE ls_aus_d-datv1 OR ls_log-datb1 NE ls_aus_d-datb1
          OR ls_log-ankey NE ls_aus_d-ankey OR ls_log-name NE ls_aus_d-name OR ls_log-stras NE ls_aus_d-stras
          OR ls_log-hausn NE ls_aus_d-hausn OR ls_log-plz NE ls_aus_d-plz OR ls_log-ort NE ls_aus_d-ort.

          ls_aus_d-tw_status = 'APPROVED'.

          MOVE-CORRESPONDING EXACT ls_aus_d TO ls_log.
          ls_log-a1mnr = ls_a1_hdr-a1mnr.
          ls_log-vp_date = ls_a1_hist-date_from.
          ls_log-vp_time = ls_a1_hist-time_from.
          ls_log-vp_action = 'CHANGE'.

          APPEND ls_log TO gt_log.
          APPEND ls_aus_d TO gt_aus_d.
          CONTINUE.
        ENDIF.
      ENDIF.
    ENDIF.
  ENDLOOP.

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  GENERATE_CSV
*&---------------------------------------------------------------------*
*       Generate csv file from fetched data
*----------------------------------------------------------------------*
FORM generate_csv .
  DATA: ls_aus_d TYPE zhr_sst_concur_reisen_output_s.
  DATA: ls_aus_final TYPE zhr_sst_concur_reisen_output_1.
  DATA: ls_csv_row TYPE LINE OF truxs_t_text_data.
  FIELD-SYMBOLS: <fs_csv_row>.

  CLEAR: gt_aus_final.
  LOOP AT gt_aus_d INTO ls_aus_d.
    CLEAR: ls_aus_final.
    CONCATENATE '"' ls_aus_d-trip_id '"' INTO ls_aus_final-trip_id.
    CONCATENATE '"' ls_aus_d-pernr '"' INTO ls_aus_final-pernr.
    CONCATENATE '"' ls_aus_d-pernr_rba '"' INTO ls_aus_final-pernr_rba.
    CONCATENATE '"' ls_aus_d-zland '"' INTO ls_aus_final-zland.
    CONCATENATE '"' ls_aus_d-datv1 '"' INTO ls_aus_final-datv1.
    CONCATENATE '"' ls_aus_d-datb1 '"' INTO ls_aus_final-datb1.
    CONCATENATE '"' ls_aus_d-dates '"' INTO ls_aus_final-dates.
    CONCATENATE '"' ls_aus_d-times '"' INTO ls_aus_final-times.
    CONCATENATE '"' ls_aus_d-ankey '"' INTO ls_aus_final-ankey.
    CONCATENATE '"' ls_aus_d-name '"' INTO ls_aus_final-name.
    CONCATENATE '"' ls_aus_d-stras '"' INTO ls_aus_final-stras.
    CONCATENATE '"' ls_aus_d-hausn '"' INTO ls_aus_final-hausn.
    CONCATENATE '"' ls_aus_d-plz '"' INTO ls_aus_final-plz.
    CONCATENATE '"' ls_aus_d-ort '"' INTO ls_aus_final-ort.
    CONCATENATE '"' ls_aus_d-tw_status '"' INTO ls_aus_final-tw_status.
    CONCATENATE '"' ls_aus_d-fdf_kostl_pernr '"' INTO ls_aus_final-fdf_kostl_pernr.
    CONCATENATE '"' ls_aus_d-fdf_aufnr_trip '"' INTO ls_aus_final-fdf_aufnr_trip.

    APPEND ls_aus_final TO gt_aus_final.
  ENDLOOP.

  CALL FUNCTION 'SAP_CONVERT_TO_TEX_FORMAT'
    EXPORTING
      i_field_seperator    = p_seprat
    TABLES
      i_tab_sap_data       = gt_aus_final
    CHANGING
      i_tab_converted_data = gt_csv_table
    EXCEPTIONS
      conversion_failed    = 4.

  IF sy-subrc <> 0.
    MESSAGE ID 'ZHR_SST_CONCUR_MC' TYPE 'E' NUMBER 002.
    STOP.
  ENDIF.

  ls_csv_row = 'TRIP_ID,PERNR,PERNR_RBA,ZLAND,DATV1,DATB1,DATES,TIMES,ANKEY,NAME,STRAS,HAUSN,PLZ,ORT,TW_STATUS,FDF_KOSTL_PERNR,FDF_AUFNR_TRIP'.
  INSERT ls_csv_row INTO gt_csv_table INDEX 1.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  DOWNLOAD_CSV
*&---------------------------------------------------------------------*
*       Perform download based on the selection screen
*----------------------------------------------------------------------*
FORM download_csv .
  DATA: ls_aus_d LIKE LINE OF gt_aus_d.

  IF p_test IS INITIAL. " productive mode
* Download the csv file
    IF p_lm IS NOT INITIAL.                       " Download to local machine
      PERFORM download_csv_lm.
    ELSE.                                         " Save to AL11
      PERFORM write_data_ftp.
    ENDIF.
  ELSE.                 " test mode
    PERFORM print_output.
  ENDIF.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  DOWNLOAD_CSV_LM
*&---------------------------------------------------------------------*
*       Download the csv file to local machine
*----------------------------------------------------------------------*
FORM download_csv_lm .
  FIELD-SYMBOLS: <fs_csv> LIKE LINE OF gt_csv_table.

  CONCATENATE p_lmp '\' p_filen INTO gv_filepath.

* Eliminate tab symbols from internal table
  LOOP AT gt_csv_table ASSIGNING <fs_csv>.
    IF <fs_csv> CS cl_abap_char_utilities=>horizontal_tab.
      REPLACE ALL OCCURRENCES OF cl_abap_char_utilities=>horizontal_tab IN <fs_csv> WITH ''.
    ENDIF.
  ENDLOOP.
* Save the file on local machine
  CALL FUNCTION 'GUI_DOWNLOAD'
    EXPORTING
      filename = gv_filepath
    TABLES
      data_tab = gt_csv_table.

  IF sy-subrc <> 0.
    MESSAGE ID 'ZHR_SST_CONCUR_MC' TYPE 'E' NUMBER 001.
  ELSE.
    WRITE: TEXT-004, /.
  ENDIF.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  PRINT_OUTPUT
*&---------------------------------------------------------------------*
*       Print CSV file content from table gt_csv_table
*----------------------------------------------------------------------*
FORM print_output .
  DATA: ls_csv LIKE LINE OF gt_csv_table.
  LOOP AT gt_csv_table INTO ls_csv.
    WRITE: ls_csv.
  ENDLOOP.
ENDFORM.
