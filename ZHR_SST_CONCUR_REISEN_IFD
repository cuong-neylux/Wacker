*----------------------------------------------------------------------*
FORM write_data_ftp .

  DATA: dsn      TYPE fileextern,
        msg(128),
        r_file   TYPE ys_ftpfile. "YSTRANSP-RFILENAME. "

  DATA: rf_descr TYPE REF TO cl_abap_structdescr,
        rf_conv  TYPE REF TO cl_simple_csv_converter.
  DATA: lt_comp TYPE abap_compdescr_tab,
        ls_comp TYPE LINE OF abap_compdescr_tab.
  DATA: lv_names TYPE string.
  DATA: lv_path TYPE ys_ftpfile. "YS_FTPFILE.
  DATA: ls_csv LIKE LINE OF gt_csv_table.
  DATA: lv_filep TYPE ys_ftpfile.


  CONCATENATE 'SST_Deloitte_' sy-datum '.csv' INTO p_filen.
  CONCATENATE '' p_filen INTO lv_filep.
  CONCATENATE '/' sy-sysid '_R3WRITE/hr-sf/' p_filen INTO p_asp.

  dsn = p_asp.

  " IF p_edi = abap_true.   "Employee directory interface

  " Dataset öffnen
  OPEN DATASET dsn FOR OUTPUT IN TEXT MODE ENCODING DEFAULT
    MESSAGE msg.
  IF sy-subrc = 0.
    LOOP AT gt_csv_table INTO ls_csv.
      TRANSFER ls_csv TO dsn.
    ENDLOOP.

    CLOSE DATASET dsn.
  ELSE.
    MESSAGE e001(ys) WITH msg.
  ENDIF.

  r_file = p_filen. "Remotefile-Name

  IF sy-sysid = 'WE5' OR sy-sysid = 'WK5'.
    "lv_path = '/ftphrsf/Test_Deloitte'.
    lv_path = 'Test_Deloitte'.
  ELSEIF sy-sysid = 'WP5'.
    "lv_path = '/ftphrsf/Prod_Deloitte'.
    lv_path = 'Prod_Deloitte'.
  ENDIF.

* FTP Transfer
  CALL FUNCTION 'Y_S_TRANS'
    EXPORTING
      modul                   = p_modul
      rfile                   = r_file "Name File auf FTP
      lfile                   = lv_filep "p_filef "Pfad und Name auf r3write
      rpath                   = lv_path "'/ftphrqtx/' "Pfad auf FTP Server
      ftpmode                 = 'P' "Transfer nach FTP Server
*     ASCII                   =
    EXCEPTIONS
      wrong_ftp_mode          = 1
      no_authority            = 2
      no_authority_c_function = 3
      module_not_found        = 4
      lpath_not_found         = 5
      logon_error             = 6
      rpath_file_not_found    = 7
      rhost_not_reached       = 8
      other_errors            = 9
      OTHERS                  = 10.
  IF sy-subrc <> 0.
    MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
            WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.
  ENDIF.
ENDFORM.
