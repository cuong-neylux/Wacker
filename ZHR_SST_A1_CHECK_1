*&---------------------------------------------------------------------*
*&      Form  UPDATE_DB
*&---------------------------------------------------------------------*
FORM update_db USING iv_mail.
  FIELD-SYMBOLS: <fs_result> TYPE zhrsst_a1_1.
  LOOP AT gt_result_mail ASSIGNING <fs_result>.
    IF iv_mail = 'M'. "mail
      <fs_result>-email_informed = 'X'.
    ELSE. "reminder
      <fs_result>-email_reminded = 'X'.
    ENDIF.
  ENDLOOP.

  MODIFY zhrsst_a1_1 FROM TABLE gt_result_mail.
  COMMIT WORK AND WAIT.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  GET_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM get_data.
  DATA ls_p01a1_stat TYPE p01a1_stat.
  DATA lt_p01a1_hist TYPE TABLE OF p01a1_hist.
  DATA ls_p01a1_hist TYPE p01a1_hist.

  SELECT * FROM p01a1_stat INTO TABLE gt_p01a1_stat WHERE mzbeg >= p_begda AND mzend <= p_endda.
  SORT  gt_p01a1_stat BY guid ASCENDING.

  CLEAR: lt_p01a1_hist.
  IF p_warn IS INITIAL.
    SELECT * FROM p01a1_hist INTO TABLE lt_p01a1_hist WHERE msgty = 'E'.
  ELSE.
    SELECT * FROM p01a1_hist INTO TABLE lt_p01a1_hist WHERE msgty = 'E' OR msgty = 'W'.
  ENDIF.
  SORT lt_p01a1_hist BY guid ASCENDING.

  LOOP AT gt_p01a1_stat INTO ls_p01a1_stat.
    CLEAR: ls_p01a1_hist.
    READ TABLE lt_p01a1_hist INTO ls_p01a1_hist WITH KEY guid = ls_p01a1_stat-guid.
    IF sy-subrc = 0.
      APPEND ls_p01a1_hist TO gt_p01a1_hist.
    ENDIF.
  ENDLOOP.

* New B2A process
  IF p_warn IS INITIAL.
    SELECT * FROM pc01b2a_sv_p_hi
         INTO TABLE gt_pc01b2a_sv_p_hi
         WHERE ( msgty = 'E'
         AND report = 'RP_PAYDE_B2A_SV_UNPACK' )
        OR ( msgty = 'E'
         AND report = 'RP_PAYDE_B2A_SV_COLLECTOR' ).
  ELSE.
    SELECT * FROM pc01b2a_sv_p_hi
         INTO TABLE gt_pc01b2a_sv_p_hi
         WHERE ( msgty = 'E' OR  msgty = 'W' )
         AND ( report = 'RP_PAYDE_B2A_SV_UNPACK'
         OR  report = 'RP_PAYDE_B2A_SV_COLLECTOR' ).
  ENDIF.

  SELECT * FROM zhrsst_a1_1 INTO TABLE gt_zhrsst_a1_1 WHERE begda >= p_begda AND endda <= p_endda.

  SELECT * FROM /nyx/a1_hdr INTO TABLE gt_a1_hdr WHERE begda >= p_begda AND endda <= p_endda.

  SELECT * FROM /nyx/a1_hist INTO TABLE gt_a1_hist WHERE begda >= p_begda AND endda <= p_endda.
ENDFORM.  "get_data
*&---------------------------------------------------------------------*
*&      Form  SUBMIT_CONTROL_REPORT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM submit_control_report .
  DATA: lv_jobname  TYPE btcjob VALUE 'ZHR_SST_A1_CONTROL',
        lv_jobcount TYPE btcjobcnt.

  CALL FUNCTION 'JOB_OPEN'
    EXPORTING
      jobname  = lv_jobname
    IMPORTING
      jobcount = lv_jobcount.

  SUBMIT zhr_sst_a1_control
    WITH p_begda = p_begda
    WITH p_endda  = p_endda
    VIA JOB lv_jobname NUMBER lv_jobcount
    AND RETURN.

  CALL FUNCTION 'JOB_CLOSE'
    EXPORTING
      jobname   = lv_jobname
      jobcount  = lv_jobcount
      strtimmed = 'X'.

  WAIT UP TO 10 SECONDS.

  REFRESH: gt_zhrsst_a1_1.
  SELECT * FROM zhrsst_a1_1 INTO TABLE gt_zhrsst_a1_1 WHERE begda >= p_begda AND endda <= p_endda.

ENDFORM.
