        APPEND ls_display_data TO lt_display_data.
      ENDIF.
      CLEAR: ls_display_data, ls_a1_hdr.
    ENDLOOP.
    CLEAR: lt_p01a1_stat, ls_p01a1_stat.
  ENDIF.
ENDFORM.


*&---------------------------------------------------------------------*
*&      Form  SEND_MAIL
*&---------------------------------------------------------------------*
FORM send_mail.
  IF p_mail IS NOT INITIAL.
    /nyx/cl_a1_util=>send_mail(
      EXPORTING
        iv_mailtype = '061'
        is_message = ls_message
        iv_sender_uid       = p_user
        iv_recipient_mail   = p_mail
        iv_send_immediately = 'X'             "
        it_key_value_param       = lt_key_value_param
      RECEIVING
        ev_success          = lv_success
    ).
    IF lv_success IS INITIAL.
      MESSAGE e135(/nyx/a1).
    ENDIF.
  ELSE.
    WRITE:/'Please give a valid Sender and email address'.
  ENDIF.
ENDFORM.
