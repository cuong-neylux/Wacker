*&---------------------------------------------------------------------*
*&      Form  CHECK_DATA
*&---------------------------------------------------------------------*
FORM check_data.
*DXA1 tickbox is clicked
*Check A1->B2A
  IF p_dxa1 IS NOT INITIAL.
    SELECT * FROM /nyx/a1_hdr INTO TABLE lt_a1_hdr
      WHERE pernr = p_pernr
      AND begda >= p_begda
      AND endda <= p_endda
      AND status = 'APPROVED_B2A'
      AND subty = 'DXA1'.

    LOOP AT lt_a1_hdr INTO ls_a1_hdr.
      SELECT * FROM p01a1_stat INTO ls_p01a1_stat     "#EC CI_A822_0001
        WHERE mzbeg = ls_a1_hdr-begda
        AND   mzend = ls_a1_hdr-endda
        AND  guid_cnect = ls_a1_hdr-guid_cnect.
      ENDSELECT.
      IF ls_p01a1_stat-mdtyp = '2'
        AND ls_p01a1_stat-status = '23'.
      ELSE.
        ls_display_data = CORRESPONDING #( BASE ( ls_display_data )  ls_a1_hdr ).
        APPEND ls_display_data TO lt_display_data.
      ENDIF.
      CLEAR: ls_p01a1_stat, ls_display_data.
    ENDLOOP.
    CLEAR: lt_a1_hdr, ls_a1_hdr.

*Check B2A->A1
    SELECT * FROM p01a1_stat INTO TABLE lt_p01a1_stat
     WHERE pernr = p_pernr
     AND mzbeg >= p_begda
     AND mzend <= p_endda
     AND   mdtyp = '2'
     AND   status = '23'.

    LOOP AT lt_p01a1_stat INTO ls_p01a1_stat.
      SELECT * FROM /nyx/a1_hdr INTO ls_a1_hdr        "#EC CI_A822_0001
        WHERE begda = ls_p01a1_stat-mzbeg
        AND   endda = ls_p01a1_stat-mzend
        AND  guid_cnect = ls_p01a1_stat-guid_cnect
        AND subty = 'DXA1'.
      ENDSELECT.
      IF ls_a1_hdr-status = 'APPROVED_B2A'.
      ELSE.
        ls_display_data = CORRESPONDING #( BASE ( ls_display_data )  ls_p01a1_stat ).
        APPEND ls_display_data TO lt_display_data.
      ENDIF.
      CLEAR: ls_display_data, ls_a1_hdr.
    ENDLOOP.
    CLEAR: lt_p01a1_stat, ls_p01a1_stat.
  ENDIF.
*DXAV tickbox is clicked
  IF p_dxav IS NOT INITIAL.
    SELECT * FROM /nyx/a1_hdr INTO TABLE lt_a1_hdr
      WHERE pernr = p_pernr
      AND begda >= p_begda
      AND endda <= p_endda
      AND status = 'APPROVED_B2A'
      AND subty = 'DXAV'.

    LOOP AT lt_a1_hdr INTO ls_a1_hdr.
      SELECT * FROM p01a1_stat INTO ls_p01a1_stat     "#EC CI_A822_0001
        WHERE mzbeg = ls_a1_hdr-begda
        AND   mzend = ls_a1_hdr-endda
        AND  guid_cnect = ls_a1_hdr-guid_cnect.
      ENDSELECT.
      IF ls_p01a1_stat-mdtyp = '2'
        AND ls_p01a1_stat-status = '23'.
      ELSE.
        ls_display_data = CORRESPONDING #( BASE ( ls_display_data )  ls_a1_hdr ).
        APPEND ls_display_data TO lt_display_data.
      ENDIF.
      CLEAR: ls_p01a1_stat, ls_display_data.
    ENDLOOP.
    CLEAR: lt_a1_hdr, ls_a1_hdr.

*Check B2A->A1
    SELECT * FROM p01a1_stat INTO TABLE lt_p01a1_stat
     WHERE pernr = p_pernr
     AND mzbeg >= p_begda
     AND mzend <= p_endda
     AND   mdtyp = '2'
     AND   status = '23'.

    LOOP AT lt_p01a1_stat INTO ls_p01a1_stat.
      SELECT * FROM /nyx/a1_hdr INTO ls_a1_hdr        "#EC CI_A822_0001
        WHERE begda = ls_p01a1_stat-mzbeg
        AND   endda = ls_p01a1_stat-mzend
        AND  guid_cnect = ls_p01a1_stat-guid_cnect
        AND subty = 'DXAV'.
      ENDSELECT.
      IF ls_a1_hdr-status = 'APPROVED_B2A'.
      ELSE.
        ls_display_data = CORRESPONDING #( BASE ( ls_display_data )  ls_p01a1_stat ).
        APPEND ls_display_data TO lt_display_data.
      ENDIF.
      CLEAR: ls_display_data, ls_a1_hdr.
    ENDLOOP.
    CLEAR: lt_p01a1_stat, ls_p01a1_stat.
  ENDIF.
*DXMM tickbox is clicked
  IF p_dxmm IS NOT INITIAL.
    SELECT * FROM /nyx/a1_hdr INTO TABLE lt_a1_hdr
      WHERE pernr = p_pernr
      AND begda >= p_begda
      AND endda <= p_endda
      AND status = 'APPROVED_B2A'
      AND subty = 'DXMM'.

    LOOP AT lt_a1_hdr INTO ls_a1_hdr.
      SELECT * FROM p01a1_stat INTO ls_p01a1_stat     "#EC CI_A822_0001
